{
  "name": "@fantasticfour/dotenvx-next",
  "version": "0.2.4",
  "type": "module",
  "description": "Next.js plugin that loads dotenvx secrets early — before any user code evaluates — by injecting an init bundle into webpack/turbopack runtime files at build time.",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinnymac/dotenvx-next.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./next-env": {
      "import": "./dist/next-env-compat.mjs",
      "require": "./dist/next-env-compat.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:publish": "changeset publish"
  },
  "peerDependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "@dotenvx/dotenvx": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.0",
    "@typescript/native-preview": "7.0.0-dev.20260615.1",
    "@vitest/coverage-v8": "^4.1.9",
    "next": "^16.2.9",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.6",
  "volta": {
    "node": "24.15.0",
    "pnpm": "11.0.6"
  },
  "license": "MIT",
  "author": "Vincent Taverna <vinnymac@gmail.com> (https://github.com/vinnymac)",
  "homepage": "https://github.com/vinnymac/dotenvx-next#readme",
  "bugs": {
    "url": "https://github.com/vinnymac/dotenvx-next/issues"
  },
  "keywords": [
    "dotenvx",
    "next.js",
    "nextjs",
    "env",
    "secrets",
    "encryption",
    "webpack",
    "turbopack",
    "plugin"
  ]
}
