{
  "name": "@fantasticfour/dotenvx-next",
  "version": "0.2.1",
  "type": "module",
  "description": "Next.js plugin that loads dotenvx secrets early — before any user code evaluates — by injecting an init bundle into webpack/turbopack runtime files at build time.",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinnymac/dotenvx-next.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./next-env": {
      "import": "./dist/next-env-compat.mjs",
      "require": "./dist/next-env-compat.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:publish": "changeset publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "webpack": "^5.106.2"
  },
  "lint-staged": {
    "**/*": "biome format --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.13.1"
  },
  "license": "MIT"
}
